# Copy to .env and fill in your secrets
HUBE_DOMAIN=your-host.your-tailnet.ts.net

# Required: bearer token the API requires on every request (except /health).
# The server refuses to start without it. Generate one with:
#   openssl rand -hex 32
HUBE_API_TOKEN=

# Optional external service integrations
MONKEYAPI_URL=
MONKEYAPI_KEY=
PAYPINGA_URL=
PAYPINGA_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
